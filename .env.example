# ──────────────────────────────
# App
# ──────────────────────────────
NEXT_PUBLIC_APP_NAME="ParkingBook"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@parkingbook.com

# ──────────────────────────────
# Database (SQLite for development)
# ──────────────────────────────
DB_DIALECT=sqlite
DB_STORAGE=./database/parking.db

# ──────────────────────────────
# Database (MySQL / PostgreSQL for production)
# ──────────────────────────────
# DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=parking_book
# DB_USER=root
# DB_PASSWORD=your_password

# ──────────────────────────────
# JWT
# ──────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=7d

# ──────────────────────────────
# Encryption
# ──────────────────────────────
ENCRYPTION_KEY=change_this_to_a_random_32_char_string

# ──────────────────────────────
# Payment Gateway
# ──────────────────────────────
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxx

# ──────────────────────────────
# Email (SMTP)
# ──────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password

# ──────────────────────────────
# SMS (Twilio)
# ──────────────────────────────
# TWILIO_ACCOUNT_SID=xxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_PHONE_NUMBER=+1234567890

# ──────────────────────────────
# Rate Limiting
# ──────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ──────────────────────────────
# Logging
# ──────────────────────────────
LOG_LEVEL=debug
